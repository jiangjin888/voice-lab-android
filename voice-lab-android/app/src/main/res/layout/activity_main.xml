<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 语音识别 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎤 语音识别"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="空闲"
                android:textSize="13sp"
                android:textColor="@color/primary"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/micBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🎙️ 开始录音"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="录音状态："
                android:textSize="12sp"
                android:textColor="@color/muted"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/partialText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="40dp"
                android:text="—"
                android:textSize="16sp"
                android:background="#f8fafc"
                android:padding="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ 最近识别成功："
                android:textSize="12sp"
                android:textColor="@color/muted"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/finalText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="40dp"
                android:text=""
                android:textSize="16sp"
                android:textColor="@color/primary_dark"
                android:background="#eef2ff"
                android:padding="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/diagText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/muted"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <!-- 文字输入 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌨️ 文字输入"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/textInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:hint="例如：明天上午9点做细胞培养实验，从9点到11点"
                android:inputType="textMultiLine"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/sendBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="提交并记录"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 筛选 / 导出 / 设置 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/filterBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🔍 筛选"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/exportBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="⬇️ 导出"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/settingsBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="⚙️ 设置"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- 次日跟进 -->
        <LinearLayout
            android:id="@+id/fuCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#fffbeb"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰ 待确认完成情况"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#b45309" />

            <LinearLayout
                android:id="@+id/fuList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- 任务与实验 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 任务与实验记录"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:id="@+id/taskList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/taskEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="还没有记录，开始说话或输入文字吧。"
            android:textColor="@color/muted"
            android:gravity="center"
            android:padding="14dp" />

        <!-- 语句记录 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 全部语句记录"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:id="@+id/sentList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/sentEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无语句。"
            android:textColor="@color/muted"
            android:gravity="center"
            android:padding="14dp" />

    </LinearLayout>
</ScrollView>
